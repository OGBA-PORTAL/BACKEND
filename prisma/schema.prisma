// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RA
  CHURCH_ADMIN
  ASSOCIATION_OFFICER
  SYSTEM_ADMIN
}

enum AccountStatus {
  PENDING_ACTIVATION
  ACTIVE
  SUSPENDED
}

model User {
  id        String   @id @default(uuid())
  raNumber  String   @unique
  password  String // Hashed
  
  firstName String
  lastName  String
  
  role      Role     @default(RA)
  status    AccountStatus @default(PENDING_ACTIVATION)
  
  // Relations
  churchId  String?
  church    Church?   @relation(fields: [churchId], references: [id])
  
  rankId    String?
  rank      Rank?     @relation(fields: [rankId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Church {
  id        String   @id @default(uuid())
  code      String   @unique // The "CCC" in RA number
  name      String
  
  users     User[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("churches")
}

model Rank {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "Assistant Intern"
  level     Int      @unique // For ordering: 1, 2, 3...
  
  users     User[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("ranks")
}

// Placeholder for Exam System - to be expanded
model Exam {
  id        String   @id @default(uuid())
  title     String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("exams")
}
